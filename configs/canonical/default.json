{
  "planner": {
    "provider": "openai_compatible",
    "model_name": "Qwen/Qwen3.5-122B-A10B",
    "connection": "local",
    "temperature": 0.6,
    "top_p": 0.95,
    "max_tokens": 8192,
    "extra_body": {"chat_template_kwargs": {"enable_thinking": true}}
  },
  "text_segmentor": {
    "provider": "openai_compatible",
    "model_name": "gpt-5",
    "connection": "remote",
    "temperature": 0.3,
    "top_p": 0.95,
    "max_tokens": 1600,
    "extra_body": {}
  },
  "multimodal_segmentor": {
    "provider": "openai_compatible",
    "model_name": "Qwen/Qwen3.5-122B-A10B",
    "connection": "local",
    "temperature": 0.3,
    "top_p": 0.95,
    "max_tokens": 1600,
    "extra_body": {"chat_template_kwargs": {"enable_thinking": false}}
  },
  "captioner": {
    "provider": "openai_compatible",
    "model_name": "Qwen/Qwen3.5-122B-A10B",
    "connection": "local",
    "temperature": 0.6,
    "top_p": 0.95,
    "max_tokens": 3200,
    "extra_body": {"chat_template_kwargs": {"enable_thinking": false}}
  },
  "transcriber": {
    "enabled": true,
    "backend": "faster_whisper",
    "model_size_or_path": "small",
    "device": "cpu",
